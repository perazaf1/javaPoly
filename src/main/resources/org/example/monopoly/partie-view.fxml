<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.monopoly.PartieController"
            styleClass="root-dark">

    <!-- Haut : infos du tour -->
    <top>
        <HBox alignment="CENTER" spacing="30.0" styleClass="header-bar">
            <Label fx:id="labelTour" text="Tour 1" styleClass="label-tour"/>
            <Label fx:id="labelJoueurCourant" text="Joueur" styleClass="label-joueur-courant"/>
            <Label fx:id="labelDes" text="Dés : -" styleClass="label-des"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Statistiques" onAction="#ouvrirStats" styleClass="btn-stats"/>
            <Button text="Sauvegarder" onAction="#sauvegarderPartie" styleClass="btn-save"/>
        </HBox>
    </top>

    <!-- Centre : plateau avec overlay pour cartes -->
    <center>
        <StackPane fx:id="zoneOverlay">
            <VBox alignment="CENTER" spacing="5">
                <padding>
                    <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                </padding>
                <!-- Zone pions au-dessus du plateau -->
                <HBox fx:id="zonePions" alignment="CENTER" spacing="12" styleClass="zone-pions">
                    <padding>
                        <Insets bottom="4.0" left="10.0" right="10.0" top="4.0"/>
                    </padding>
                </HBox>
                <!-- Plateau -->
                <GridPane fx:id="grillePlateau" alignment="CENTER" hgap="1" vgap="1"/>
            </VBox>
        </StackPane>
    </center>

    <!-- Droite : panneau d'actions et infos -->
    <right>
        <VBox spacing="12.0" prefWidth="310" styleClass="panneau-lateral">

            <Label text="Actions" styleClass="titre-section"/>

            <!-- Zone dés visuels -->
            <HBox fx:id="zoneDes" alignment="CENTER" spacing="15" styleClass="zone-des">
                <padding>
                    <Insets bottom="6.0" top="2.0"/>
                </padding>
            </HBox>

            <Button fx:id="btnLancerDes" text="Lancer les dés" onAction="#lancerDes"
                    prefWidth="275" prefHeight="42" styleClass="btn-action"/>

            <Button fx:id="btnAcheter" text="Acheter" onAction="#acheterPropriete"
                    prefWidth="275" prefHeight="36" disable="true" styleClass="btn-achat"/>

            <Button fx:id="btnFinTour" text="Fin du tour" onAction="#finDuTour"
                    prefWidth="275" prefHeight="36" disable="true" styleClass="btn-fin-tour"/>

            <Button fx:id="btnPayerPrison" text="Payer 50$ (sortir de prison)" onAction="#payerPrison"
                    prefWidth="275" prefHeight="36" visible="false" styleClass="btn-prison"/>

            <Separator/>

            <Label text="Joueurs" styleClass="titre-section"/>
            <VBox fx:id="panneauJoueurs" spacing="6.0"/>

            <Separator/>

            <Label text="Case actuelle" styleClass="titre-section"/>
            <Label fx:id="labelCaseActuelle" text="-" styleClass="label-info" wrapText="true"/>

        </VBox>
    </right>

    <!-- Bas : log des messages -->
    <bottom>
        <VBox styleClass="panneau-log">
            <TextArea fx:id="logMessages" prefHeight="110" editable="false"
                      wrapText="true" styleClass="log-area"/>
        </VBox>
    </bottom>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.monopoly.MenuController"
      styleClass="root-dark">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Region prefHeight="60"/>

    <Label text="JAVAPOLY" styleClass="titre-principal"/>

    <Label text="Le Monopoly en JavaFX" styleClass="sous-titre"/>

    <Region prefHeight="40"/>

    <VBox alignment="CENTER" spacing="15.0">
        <Button text="Nouvelle Partie" onAction="#nouvellePartie"
                prefWidth="280" prefHeight="50" styleClass="btn-primary"/>

        <Button text="Charger une partie" onAction="#chargerPartie"
                prefWidth="280" prefHeight="50" styleClass="btn-secondary"/>

        <Button text="Quitter" onAction="#quitter"
                prefWidth="280" prefHeight="50" styleClass="btn-danger"/>
    </VBox>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.monopoly.ConfigPartieController"
      styleClass="root-dark">
    <padding>
        <Insets bottom="30.0" left="60.0" right="60.0" top="30.0"/>
    </padding>

    <Label text="Configuration de la partie" styleClass="titre-principal" style="-fx-font-size: 36px;"/>

    <Label text="Nombre de joueurs (2 a 6) :" styleClass="label-config"/>
    <HBox alignment="CENTER" spacing="15.0">
        <Spinner fx:id="spinnerNbJoueurs" prefWidth="90"/>
        <Button text="Valider" onAction="#validerNbJoueurs" styleClass="btn-secondary"/>
    </HBox>

    <!-- Zone dynamique pour les champs de saisie des joueurs -->
    <VBox fx:id="zoneJoueurs" spacing="12.0" alignment="CENTER">
        <padding>
            <Insets top="10.0"/>
        </padding>
    </VBox>

    <Label fx:id="labelErreur" styleClass="label-erreur" text=""/>

    <HBox alignment="CENTER" spacing="20.0">
        <padding>
            <Insets top="15.0"/>
        </padding>
        <Button text="Retour" onAction="#retourMenu"
                prefWidth="160" prefHeight="45" styleClass="btn-secondary"/>
        <Button fx:id="btnLancer" text="Lancer la partie" onAction="#lancerPartie"
                prefWidth="220" prefHeight="45" disable="true" styleClass="btn-success"/>
    </HBox>
</VBox>
